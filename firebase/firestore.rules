rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.email == 'foxsd520@gmail.com'; }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if (signedIn() && request.auth.uid == uid) || isAdmin();
    }

    match /developer_requests/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();

      match /ratings/{uid} {
        allow read: if signedIn();
        allow write: if signedIn() && uid == request.auth.uid;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow delete: if isAdmin();
      }
    }

    match /chat/{msgId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /store_settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if signedIn() && request.resource.data.developerId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.developerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
